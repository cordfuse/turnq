{
  "name": "@cordfuse/turnq",
  "version": "0.4.2",
  "description": "Named-channel turn coordinator. HTTP actions, SSE notifications.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./client": {
      "bun": "./src/client.ts",
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./local": {
      "types": "./types/local.d.ts",
      "bun": "./src/local.ts"
    },
    "./coordinator": {
      "bun": "./src/coordinator.ts",
      "import": "./dist/coordinator-node.js",
      "types": "./dist/coordinator-node.d.ts"
    }
  },
  "files": [
    "dist",
    "src/client.ts",
    "src/errors.ts",
    "src/protocol.ts",
    "src/local.ts",
    "src/coordinator.ts",
    "src/coordinator-node.ts",
    "types",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "express": "^4.19.2"
  }
}
